{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "ExceptionMiddleware": "Error"
    },
    "LogDirectory": "Logs"
  },
  "DetailedErrors": true, 
  "LoggingOverrides": {
    "CriticalComponents": {
      "Database": "Debug",  
      "ExternalApi": "Information"
    }
  },

  "ConnectionStrings": {
    "DefaultConnection": ""
  }
}
